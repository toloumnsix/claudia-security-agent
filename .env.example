# Eliza Security Agent - Environment Configuration
# Copy this file to .env.local for local development.
# API routes are served by the Vite dev/preview server on the same origin.

# OpenRouter credentials
OPENROUTER_API_KEY=your_openrouter_api_key_here
APP_URL=http://localhost:5173
APP_NAME=Eliza Security Agent

# Optional only if the frontend is served from a different origin than the Vite API routes.
# VITE_API_BASE_URL=

# GitHub token is optional but recommended for higher rate limits.
# GITHUB_TOKEN=ghp_your_github_token_here
